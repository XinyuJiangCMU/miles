--- runtime/hsa-runtime/core/runtime/runtime.cpp.orig	2026-06-24 04:57:19.948683144 +0000
+++ runtime/hsa-runtime/core/runtime/runtime.cpp	2026-06-24 04:57:19.963682871 +0000
@@ -386,6 +386,13 @@
         amdgpu_bo_metadata zero_metadata = {0};
         memset(zero_metadata.umd_metadata, 0, sizeof(uint32_t));
         DRM_CALL(amdgpu_bo_set_metadata(it->second.ldrm_bo, &zero_metadata));
+
+        // Release the exporter-side libdrm BO reference taken by amdgpu_bo_import in
+        // IPCCreate. Without this the import reference outlives the kfd free below, so the
+        // kernel never reclaims the physical pages of an allocation that was ever IPC
+        // exported (regression introduced by #795 "Make IPC Handles Unique").
+        DRM_CALL(amdgpu_bo_free(it->second.ldrm_bo));
+        it->second.ldrm_bo = nullptr;
       }
 #else
       assert(!"Unimplemented!");
